                                <p>View individual accounts for details.</p>
                                <button class="first-view-btn">View</button>
                            </div>
                        </div>
                        <div class="first-notification-item">
                            <div class="first-notification-icon error">!</div>
                            <div class="first-notification-content">
                                <h4>2 accounts could benefit from improved<br>security</h4>
                                <p>Check out suggestions to improve the security<br>of 2 accounts.</p>
                                <button class="first-view-btn">View</button>
                            </div>
                        </div>
                        <div class="first-notification-item">
                            <div class="first-notification-icon warn">i</div>
                            <div class="first-notification-content">
                                <h4>Thanks for verifying 1 account!</h4>
                                <p>Thanks for verifying! The verified advertiser<br>name and location for each of these
                                    accounts<br>will now appear in your ad disclosures. We'll let<br> you know if we
                                    need more information in<br>future.</p>
                                <button class="first-text-btn">Learn more</button>
                            </div>
                        </div>
                    </div>
                </transition>
                <div class="user-section">
                    <div class="user-info">
                        <div class="user-connect">
                            <div class="user-phone">172-135-6148</div>
                            <div class="user-email">1124-4-mcc</div>
                        </div>
                        <div class="user-name">reillymalvina309@gmail.com
</div>
                    </div>
                    <div class="user-avatar">
                        R
                    </div>
                </div>
            </div>
        </div>

        <!-- 第2行：视图和广告系列选择器 -->
        <div class="view-campaign-bar">
            <div class="view-campaign-left">
                <button class="view-btn">
                    <div style="position: relative;">
                        <span style="color: #5f6368; font-size: 0.75rem; letter-spacing: 0.03rem;">View (2
                            filters)</span>
                        <span style="display: flex; flex-direction: row; justify-content: center;">
                            <span style="color: #3c4043; font-weight: 600;"
                                class="material-symbols-outlined">home</span>
                            <span class="view-btn-tt" style="padding: 3px 0 0 5px;">All
                                campaigns</span>
                        </span>
                    </div>
                    <span class="material-symbols-outlined"
                        style="padding-left: 4px; font-size: 24px; padding-right: 0px;">arrow_drop_down</span>
                    <div class="blue-line"></div>
                </button>
                <button class="campaign-view-btn">
                    <div>
                        <span style="color: #5f6368; font-size: 0.75rem; letter-spacing: 0.03rem;">Campaigns (15)</span>
                        <span class="view-btn-tt" style="padding: 3px 0 0 0px;">Select
                            a campaign</span>
                    </div>
                    <span class="material-symbols-outlined"
                        style="padding-left: 6px; font-size: 24px; padding-right: 0px;">arrow_drop_down</span>
                </button>
            </div>
        </div>

        <!-- 第3行：过滤栏 -->
        <div class="filter-bar-hd">
            <div class="filter-left">
                <span class="filter-label">Filters</span>
                <span class="filter-item">
                    <span>Campaign status:</span>
                    <span class="filter-value">Enabled, Paused</span>
                </span>
                <span class="filter-item">
                    <span>Ad group status:</span>
                    <span class="filter-value">Enabled, Paused</span>
                </span>
                <button class="add-filter-btn">
                    <span>Add filter</span>
                </button>
            </div>
            <div class="filter-right">
                <button class="save-filter-btn">
                    <span class="material-symbols-outlined">save</span>
                    <span style="font-size: 12px; font-weight: 500;">Save</span>
                </button>
            </div>
        </div>


        <!-- 第2行：工具栏 -->
        <div class="toolbar">
            <div class="toolbar-left">
                <div class="campaign-selector">
                    <button class="selector-btn">
                        <div>
                            <span style="font-size: 18px; font-weight: 500;">2</span>
                            <span style="font-size: 12px; font-weight: 500;">{{ savedLabel }}</span>
                        </div>
                        <span class="material-symbols-outlined">arrow_drop_down</span>
                    </button>
                    <span class="material-symbols-outlined" style="color: #5f6368;">Edit</span>
                </div>
            </div>
            <div class="toolbar-right">
                <div class="toolbar-right-icons">
                    <button class="tool-btn tool-btn-2item">
                        <span class="material-symbols-outlined">file_download</span>
                        <span>Download</span>
                    </button>
                    <button class="tool-btn tool-btn-2item">
                        <span class="material-symbols-outlined">access_time</span>
                        <span>Schedule</span>
                    </button>
                    <button class="tool-btn tool-btn-2item">
                        <span class="material-symbols-outlined">feedback</span>
                        <span>Feedback</span>
                    </button>
                </div>
                <div class="divider" style="height: 56px; margin: 0 10px;"></div>
                <div class="toolbar-right-editbtn">

                    <button class="tool-btn" :class="isSaved ? 'tool-item-gray' : 'tool-item-blue'" @click="handleSave">
                        <span>Reset</span>
                    </button>
                    <button class="tool-btn" :class="isSaved ? 'tool-item-gray' : 'tool-item-blue'" @click="handleSave">
                        <span>Save</span>
                    </button>
                    <button class="tool-btn tool-item-blue">
                        <span>Save as</span>
                    </button>
                    <button class="tool-btn tool-item-blue">
                        <span>Add to dashboard</span>
                    </button>
                </div>
            </div>
        </div>

        <!-- 第3行：日期选择栏 -->
<div class="content-wrapper" style="display: flex; flex-direction: column; flex: 1; min-height: 0;">
        <div style="display: flex; flex: 1; min-height: 0;">

        <div class="main-content" style="flex: 1; min-width: 0; display: flex; flex-direction: column;">
        <div class="date-bar">
            <div class="date-controls">
                <div class="date-range">
                    <div style="color: #757575;">
                        <span class="material-symbols-outlined">Undo</span>
                        <label>Undo</label>
                    </div>
                    <div>
                        <span class="material-symbols-outlined">Redo</span>
                        <label>Redo</label>
                    </div>
                </div>
            </div>
            <div class="compare-controls">
                <div class="all_accounts">
                    <button type="button" class="account-count-button" @click="openAccountPicker">
                        {{ accountText }}
                    </button>
                    <button type="button" class="account-edit-button" aria-label="Select accounts" @click="openAccountPicker">
                        <span class="material-symbols-outlined">Edit</span>
                    </button>
                </div>
                <div class="divider _ngcontent-awn-GINSU-22"></div>
                <div class="date-select" ref="dateSelectRef">
                    <div>{{ getDateOptionLabel(appliedDateOption) }}</div>
                    <div @click="toggleDatePicker" style="cursor: pointer;">
                        <div>
                            <span>{{ formattedStartDate }}{{ formattedStartDate && formattedEndDate &&
                                formattedStartDate !== formattedEndDate ? ' - ' + formattedEndDate : '' }}</span>
                            <span class="material-symbols-outlined" style="color: #5f637b;">arrow_drop_down</span>
                        </div>
                        <div style="color: rgb(60 64 67 / 38%);">
                            <span class="material-symbols-outlined">chevron_left</span>
                            <span class="material-symbols-outlined">chevron_right</span>
                        </div>
                    </div>
                </div>
                <div class="divider _ngcontent-awn-GINSU-22"></div>
                <div
                    style="color: #5f637b; margin-right: 24px; display: flex; align-items: center; flex-direction: column; gap: 2px;">
                    <span class="material-symbols-outlined" style="font-size: 25px;">filter_alt</span>
                    <div style="font-size: 8px;">Filter</div>
                </div>
                <div @click="toggleRightPanel" :class="['stat-toggle-btn', { active: showRightPanel }]">
                    <span class="material-symbols-outlined">stat_2</span>
                </div>

            </div>

            <!-- 日期选择下拉框 -->
            <transition name="date-picker">
                <div v-if="showDatePicker" class="date-picker-dropdown" @click.stop :style="dropdownStyle">
                    <div class="date-picker-container">
                        <div class="date-picker-content">
                            <!-- 左侧选项列表 -->
                            <div class="date-left-options">
                                <div class="date-custom" :class="{ active: selectedDateOption === 'custom' }"
                                    @click="selectDateOption('custom')">
                                    Custom
                                </div>

                                <div class="date-options">
                                    <div class="date-option" :class="{ active: selectedDateOption === 'today' }"
                                        @click="selectDateOption('today')">
                                        Today
                                    </div>
                                    <div class="date-option" :class="{ active: selectedDateOption === 'yesterday' }"
                                        @click="selectDateOption('yesterday')">
                                        Yesterday
                                    </div>
                                    <div class="date-option"
                                        :class="{ active: selectedDateOption === 'thisWeekSunSat' }"
                                        @click="selectDateOption('thisWeekSunSat')">
                                        This week (Sun - Today)
                                    </div>
                                    <div class="date-option"
                                        :class="{ active: selectedDateOption === 'thisWeekMonSun' }"
                                        @click="selectDateOption('thisWeekMonSun')">
                                        This week (Mon - Today)
                                    </div>
                                    <div class="date-option" :class="{ active: selectedDateOption === 'last7Days' }"
                                        @click="selectDateOption('last7Days')">
                                        Last 7 days (up to yesterday)
                                    </div>

                                    <div class="date-option"
                                        :class="{ active: selectedDateOption === 'lastWeekSunSat' }"
                                        @click="selectDateOption('lastWeekSunSat')">
                                        Last week (Sun - Sat)
                                    </div>
                                    <div class="date-option"
                                        :class="{ active: selectedDateOption === 'lastWeekMonSun' }"
                                        @click="selectDateOption('lastWeekMonSun')">
                                        Last week (Mon - Sun)
                                    </div>
                                    <div class="date-option"
                                        :class="{ active: selectedDateOption === 'lastBusinessWeek' }"
                                        @click="selectDateOption('lastBusinessWeek')">
                                        Last business week (Mon - Fri)
                                    </div>
                                    <div class="date-option" :class="{ active: selectedDateOption === 'last14Days' }"
                                        @click="selectDateOption('last14Days')">
                                        Last 14 days (up to yesterday)
                                    </div>
                                    <div class="date-option" :class="{ active: selectedDateOption === 'thisMonth' }"
                                        @click="selectDateOption('thisMonth')">
                                        This month
                                    </div>
                                    <div class="date-option" :class="{ active: selectedDateOption === 'last30Days' }"
                                        @click="selectDateOption('last30Days')">
                                        Last 30 days
                                    </div>
                                    <div class="date-option" :class="{ active: selectedDateOption === 'lastMonth' }"
                                        @click="selectDateOption('lastMonth')">
                                        Last month
                                    </div>
                                    <div class="date-option" :class="{ active: selectedDateOption === 'allTime' }"
                                        @click="selectDateOption('allTime')">
                                        All time
                                    </div>
                                </div>
                                <div class="compare-option">
                                    <span class="compare-label">Compare</span>
                                    <div :class="{ toggled: compareEnabled }" @click="compareEnabled = !compareEnabled">
                                        <div class="toggle-circle"></div>
                                    </div>
                                </div>

                            </div>
                            <!-- 右侧日历 -->
                            <div class="calendar-section">
                                <!-- 日期输入框 -->
                                <div class="date-inputs">
                                    <div class="date-input-wrapper" :class="{ active: selectingStartDate }"
                                        @click="selectStartDate">
                                        <div class="date-input-label">Start date*</div>
                                        <div class="date-input-value">{{ formattedDraftStartDate }}</div>
                                    </div>
                                    <div style="line-height: 49px;">—</div>
                                    <div class="date-input-wrapper" :class="{ active: !selectingStartDate }"
                                        @click="selectEndDate">
                                        <div class="date-input-label">End date*</div>
                                        <div class="date-input-value">{{ formattedDraftEndDate }}</div>
                                    </div>
                                </div>
                                <!-- 月份导航栏 -->
                                <div class="calendar-nav-bar">
                                    <div class="calendar-nav-month">{{ calendarMonthYear }}</div>
                                    <div class="calendar-nav-buttons">
                                        <span class="material-symbols-outlined"
                                            @click="navigateMonth(-1)">chevron_left</span>
                                        <span class="material-symbols-outlined"
                                            @click="navigateMonth(1)">chevron_right</span>
                                    </div>
                                </div>
                                <!-- 日历容器 - 可滚动 -->
                                <div class="calendar-scroll-container">
                                    <!-- 星期表头（固定在顶部） -->
                                    <div class="calendar-weekdays-fixed">
                                        <div class="weekday">S</div>
                                        <div class="weekday">M</div>
                                        <div class="weekday">T</div>
                                        <div class="weekday">W</div>
                                        <div class="weekday">T</div>
                                        <div class="weekday">F</div>
                                        <div class="weekday">S</div>
                                    </div>
                                    <!-- 可滚动的月份列表 -->
                                    <div class="calendar-months-scroll">
                                        <div v-for="monthData in calendarMonths" :key="monthData.date"
                                            class="calendar-month">
                                            <!-- 普通情况：月份标题单独一行 -->
                                            <div v-if="!monthData.showTitleInline" class="calendar-month-title">{{
                                                monthData.monthYear }}</div>
                                            <div class="calendar-days">
                                                <div v-for="(week, weekIndex) in monthData.weeks" :key="week"
                                                    class="calendar-week">
                                                    <!-- 如果需要和第一周同行的情况 -->
                                                    <div v-if="monthData.showTitleInline && weekIndex === 0"
                                                        class="calendar-month-title-inline">{{ monthData.monthYear }}
                                                    </div>
                                                    <div v-for="day in week" :key="day.date" class="calendar-day"
                                                        :class="{
                                        'other-month': !day.isCurrentMonth,
                                        'selected': isSameDay(day.date, draftStartDate),
                                        'in-range': isInRange(day.date),
                                        'start-date': isSameDay(day.date, draftStartDate) && !isSameDay(draftStartDate, draftEndDate),
                                        'end-date': isSameDay(day.date, draftEndDate) && !isSameDay(draftStartDate, draftEndDate),
                                        'single-date': isSameDay(day.date, draftStartDate) && isSameDay(draftStartDate, draftEndDate)
