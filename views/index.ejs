                <div class="account-selector">
                    <span class="account-id">1124-4-mcc</span>
                    <span class="account-phone">172-135-6148</span>
                    <span class="material-symbols-outlined">arrow_drop_down</span>
                </div>
                <div class="search-box">
                    <span class="material-symbols-outlined search-icon">search</span>
                    <input type="text" placeholder="Search for a page or campaign" class="search-input">
                </div>
            </div>
            <div class="header-right">
                <button class="header-btn" data-tooltip="Appearance">
                    <span
                        class="material-symbols-outlined material-icon-i material-icons-extended _ngcontent-awn-AWSM-16"
                        role="img" aria-hidden="true">responsive_layout</span>
                    <span class="btn-text">Appearance</span>
                </button>
                <button
                    type="button"
                    class="header-btn refresh-btn"
                    :class="{ refreshing: isRefreshing }"
                    :disabled="isRefreshing"
                    :aria-busy="isRefreshing.toString()"
                    @click="refreshPage"
                    data-tooltip="Refresh"
                >
                    <span class="material-symbols-outlined refresh-icon">refresh</span>
                    <span class="btn-text">{{ isRefreshing ? 'Refreshing' : 'Refresh' }}</span>
                </button>
                <button class="header-btn" data-tooltip="Open the quick help panel">
                    <span class="material-symbols-outlined">help</span>
                    <span class="btn-text">Help</span>
                </button>
                <button ref="firstNotificationButton" class="header-btn notification-btn" type="button"  @click.stop="toggleFirstNotifications">
                    <span class="material-symbols-outlined">notifications</span>
                    <span class="notification-badge">!</span>
                    <span class="btn-text">Notifications</span>
                </button>
                <transition name="first-notifications-transition-popup">
                    <div v-if="isFirstNotificationsOpen" ref="firstNotificationPopup" class="first-notifications-popup" @click.stop>
                        <div class="first-notifications-header">
                            Notifications
                        </div>
                        <div class="first-notification-item">
                            <div class="first-notification-icon error">!</div>
                            <div class="first-notification-content">
