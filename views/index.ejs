    <!-- Vue.js CDN -->
    <script src="/js/vue.global.js"></script>
    <script src="/app.js"></script>
    <script>
        document.addEventListener('click', (e) => {
            // popup
            const popup =
                document.querySelector('.first-notifications-popup')

            // 按钮
            const button =
                document.querySelector('.notification-btn')

            // popup 未打开
            if (!popup) {
                return
            }

            // 点击 popup 内部
            if (popup.contains(e.target)) {
                return
            }

            // 点击按钮
            if (button.contains(e.target)) {
                return
            }

            // 获取 Vue 实例
            const vm =
                document.querySelector('#app')
                    .__vue_app__
                    ._instance
                    .proxy

            // 关闭
            vm.isFirstNotificationsOpen = false
        })
    </script>
