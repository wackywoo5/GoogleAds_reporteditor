                        <span>{{ paginationText }}</span>
                        <span class="material-symbols-outlined" :class="{ muted: !canGoPreviousPage }"
                            @click="canGoPreviousPage && goToFirstPage()">first_page</span>
                        <span class="material-symbols-outlined" :class="{ muted: !canGoPreviousPage }"
                            @click="canGoPreviousPage && goToPreviousPage()">chevron_left</span>
                        <span class="material-symbols-outlined" :class="{ muted: !canGoNextPage }"
                            @click="canGoNextPage && goToNextPage()">chevron_right</span>
                        <span class="material-symbols-outlined" :class="{ muted: !canGoNextPage }"
                            @click="canGoNextPage && goToLastPage()">last_page</span>
                    </div>
                </section>

                <footer class="ga-footer">
                    <p><a href="#">Reporting is not real-time.</a> Time zone for all dates and times: (GMT+08:00) China
                        Standard Time. <a href="#">Learn more</a></p>
                    <p>Some inventory may be provided through third party intermediaries.</p>
                    <p>You'll see Media Rating Council (MRC) accreditation noted in the column header's hover text for
                        accredited metrics.</p>
                    <p>&copy; Google, 2026.</p>
                </footer>
                </template>
            </main>
        </div>

        <div v-if="previewModal" class="ga-modal-backdrop" @click.self="closePreview">
            <section v-if="previewModal.type === 'unavailable'" class="ga-preview-modal unavailable">
                <h2>Ad previews</h2>
                <p>Ad previews aren't available for this asset</p>
                <button type="button" @click="closePreview">Close</button>
            </section>
            <section v-if="previewModal.type === 'image'" class="ga-preview-modal image-preview">
                <div class="ga-preview-stage">
                    <button class="ga-preview-close" type="button" @click="closePreview">
                        <span class="material-symbols-outlined">close</span>
                    </button>
                    <h2>{{ previewModal.asset.source }}</h2>
                    <img :src="previewModal.asset.image" :alt="previewModal.asset.asset">
                </div>
                <aside class="ga-preview-details">
                    <!-- <h2>About this asset</h2> -->
                    <div class="ga-previewModal-asset-aboutinfo-aboutinfo">
                        About this asset
                    </div>
                    <h3>{{ previewModal.asset.source }}</h3>
                    <dl>
                        <dt class="ga-preview-details-title" @click="togglePreviewDetails">Details</dt>
                        <dd class="ga-preview-details-toggle">
                            <button class="ga-preview-details-toggle-button" type="button" @click.stop="togglePreviewDetails" aria-label="Toggle details">
                                <span class="material-symbols-outlined">{{ isPreviewDetailsExpanded ? 'expand_less' : 'expand_more' }}</span>
                            </button>
                        </dd>
                        <template v-if="isPreviewDetailsExpanded">
                            <dt>Asset ID</dt>
                            <dd>{{ previewModal.asset.id }}</dd>
                            <dt>Type</dt>
                            <dd>{{ previewModal.asset.assetType }}</dd>
                            <dt>Dimensions</dt>
                            <dd>{{ previewModal.asset.asset }}</dd>
                            <dt>Orientation</dt>
                            <dd>Square</dd>
                            <dt>Aspect ratio</dt>
                            <dd>1:1</dd>
                            <dt>Source</dt>
                            <dd>Advertiser</dd>
                        </template>
                    </dl>
                </aside>
            </section>
        </div>
        <div v-if="tooltip.visible" class="ga-tooltip" :style="{
                left: tooltip.x + 'px',
                top: tooltip.y + 'px'
            }">
            {{ tooltip.text }}
        </div>
    </div>
    <script src="/js/vue.global.js"></script>
    <script src="/google_ads.js"></script>
    <script>
        document.addEventListener('click', (e) => {
            // popup
            const popup =
                document.querySelector('.ga-notifications-popup')

            // 按钮
            const button =
                document.querySelector('.ga-notifications')

            // popup 未打开
            if (!popup) {
                return
            }

            // 点击 popup 内部
            if (popup.contains(e.target)) {
                return
            }

            // 点击按钮
            if (button.contains(e.target)) {
                return
            }

            // 获取 Vue 实例
            const vm =
                document.querySelector('#google-ads-app')
                    .__vue_app__
                    ._instance
                    .proxy

            // 关闭
            vm.isNotificationsOpen = false
        })
    </script>
</body>

</html>
