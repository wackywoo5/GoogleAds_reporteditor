                        </template>
                    </dl>
                </aside>
            </section>
        </div>
        <div v-if="tooltip.visible" class="ga-tooltip" :style="{
                left: tooltip.x + 'px',
                top: tooltip.y + 'px'
            }">
            {{ tooltip.text }}
        </div>
    </div>
    <script src="/js/vue.global.js"></script>
    <script src="/google_ads.js"></script>
    <script>
        document.addEventListener('click', (e) => {
            // popup
            const popup =
                document.querySelector('.ga-notifications-popup')

            // 按钮
            const button =
                document.querySelector('.ga-notifications')

            // popup 未打开
            if (!popup) {
                return
            }

            // 点击 popup 内部
            if (popup.contains(e.target)) {
                return
            }

            // 点击按钮
            if (button.contains(e.target)) {
                return
            }

            // 获取 Vue 实例
            const vm =
                document.querySelector('#google-ads-app')
                    .__vue_app__
                    ._instance
                    .proxy

            // 关闭
            vm.isNotificationsOpen = false
        })
    </script>
</body>

</html>
