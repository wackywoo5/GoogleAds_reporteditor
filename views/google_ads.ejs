<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="Cache-Control" content="no-cache">
    <meta http-equiv="pragma" content="no-cache">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Google Ads</title>
    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="/google_ads.css">
</head>

<body class="ga-body">
    <div id="google-ads-app" :class="{ 'ga-nav-collapsed': isNavCollapsed, 'ga-refreshing': isRefreshing }" v-cloak>
        <header class="ga-topbar">
            <div class="ga-topbar-left">
                <button class="ga-icon-button" type="button" aria-label="Toggle navigation" @click="toggleNavigation">
                    <span class="material-symbols-outlined">menu</span>
                </button>
                <a class="ga-brand" href="/aw/campaigns" aria-label="Google Ads campaigns">
                    <svg class="ga-ads-logo" enable-background="new 0 0 192 192" viewBox="0 0 192 192"
                        xmlns="http://www.w3.org/2000/svg">
                        <g>
                            <rect fill="none" height="192" width="192"></rect>
                            <g>
                                <rect fill="#FBBC04" height="58.67"
                                    transform="matrix(0.5 -0.866 0.866 0.5 -46.2127 103.666)" width="117.33" x="8"
                                    y="62.52"></rect>
                                <path
                                    d="M180.07,127.99L121.4,26.38c-8.1-14.03-26.04-18.84-40.07-10.74c-14.03,8.1-18.84,26.04-10.74,40.07 l58.67,101.61c8.1,14.03,26.04,18.83,40.07,10.74C183.36,159.96,188.16,142.02,180.07,127.99z"
                                    fill="#4285F4"></path>
                                <circle cx="37.34" cy="142.66" fill="#34A853" r="29.33"></circle>
                            </g>
                        </g>
                    </svg>
                    <svg class="lockup-google-logo" height="24" viewBox="0 0 74 24" width="74"
                        xmlns="http://www.w3.org/2000/svg">
                        <path
                            d="M9.24 8.19v2.46h5.88c-.18 1.38-.64 2.39-1.34 3.1-.86.86-2.2 1.8-4.54 1.8-3.62 0-6.45-2.92-6.45-6.54s2.83-6.54 6.45-6.54c1.95 0 3.38.77 4.43 1.76L15.4 2.5C13.94 1.08 11.98 0 9.24 0 4.28 0 .11 4.04.11 9s4.17 9 9.13 9c2.68 0 4.7-.88 6.28-2.52 1.62-1.62 2.13-3.91 2.13-5.75 0-.57-.04-1.1-.13-1.54H9.24zm15.76-2c-3.21 0-5.83 2.44-5.83 5.81 0 3.34 2.62 5.81 5.83 5.81s5.83-2.46 5.83-5.81c0-3.37-2.62-5.81-5.83-5.81zm0 9.33c-1.76 0-3.28-1.45-3.28-3.52 0-2.09 1.52-3.52 3.28-3.52s3.28 1.43 3.28 3.52c0 2.07-1.52 3.52-3.28 3.52zm28.58-8.03h-.09c-.57-.68-1.67-1.3-3.06-1.3C47.53 6.19 45 8.72 45 12c0 3.26 2.53 5.81 5.43 5.81 1.39 0 2.49-.62 3.06-1.32h.09v.81c0 2.22-1.19 3.41-3.1 3.41-1.56 0-2.53-1.12-2.93-2.07l-2.22.92c.64 1.54 2.33 3.43 5.15 3.43 2.99 0 5.52-1.76 5.52-6.05V6.49h-2.42v1zm-2.93 8.03c-1.76 0-3.1-1.5-3.1-3.52 0-2.05 1.34-3.52 3.1-3.52 1.74 0 3.1 1.5 3.1 3.54.01 2.03-1.36 3.5-3.1 3.5zM38 6.19c-3.21 0-5.83 2.44-5.83 5.81 0 3.34 2.62 5.81 5.83 5.81s5.83-2.46 5.83-5.81c0-3.37-2.62-5.81-5.83-5.81zm0 9.33c-1.76 0-3.28-1.45-3.28-3.52 0-2.09 1.52-3.52 3.28-3.52s3.28 1.43 3.28 3.52c0 2.07-1.52 3.52-3.28 3.52zM58 .24h2.51v17.57H58zm10.26 15.28c-1.3 0-2.22-.59-2.82-1.76l7.77-3.21-.26-.66c-.48-1.3-1.96-3.7-4.97-3.7-2.99 0-5.48 2.35-5.48 5.81 0 3.26 2.46 5.81 5.76 5.81 2.66 0 4.2-1.63 4.84-2.57l-1.98-1.32c-.66.96-1.56 1.6-2.86 1.6zm-.18-7.15c1.03 0 1.91.53 2.2 1.28l-5.25 2.17c0-2.44 1.73-3.45 3.05-3.45z">
                        </path>
                    </svg>
                    <span>Ads</span>
                </a>
                <span> </span>
                <button class="ga-account-button" type="button">
                    <span>{{ account.id }}</span>
                    <small>{{ account.phone }}</small>
                    <span class="material-symbols-outlined">arrow_drop_down</span>
                </button>
                <!-- <label class="ga-search">
                    <span class="material-symbols-outlined">search</span>
                    <input type="text" placeholder="Search for a page or campaign">
                </label> -->
            </div>
            <div class="ga-topbar-actions">
                <button class="ga-tool-button ga-tool-button--search" type="button">
                    <span class="material-symbols-outlined">search</span>
                    <span>Search</span>
                </button>
                <button class="ga-tool-button" type="button" data-tooltip="Appearance">
                    <span class="material-symbols-outlined">responsive_layout</span>
                    <span>Appearance</span>
                </button>
                <button class="ga-tool-button ga-refresh-button" type="button"
                    :class="{ refreshing: isRefreshing }" :disabled="isRefreshing"
                    :aria-busy="isRefreshing.toString()" @click="reloadData" data-tooltip="Refresh">
                    <span class="material-symbols-outlined ga-refresh-icon">refresh</span>
                    <span>Refresh</span>
                </button>
                <button class="ga-tool-button" type="button" data-tooltip="Open the quick help panel">
                    <span class="material-symbols-outlined">help</span>
                    <span>Help</span>
                </button>
                <!-- @click="isNotificationsOpen = !isNotificationsOpen" -->
                <button ref="notificationButton" class="ga-tool-button ga-notifications" type="button"
                    @click.stop="toggleNotifications">
                    <span class="material-symbols-outlined">notifications</span>
                    <span>Notifications</span>
                    <b>!</b>
                </button>
                <transition name="ga-notifications-transition-popup">
                    <div v-if="isNotificationsOpen" ref="notificationPopup" class="ga-notifications-popup" @click.stop>
                        <div class="ga-notifications-header">
                            Notifications
                        </div>
                        <div class="ga-notification-item">
                            <div class="ga-notification-icon error">!</div>
                            <div class="ga-notification-content">
                                <h4>1 account has billing announcements</h4>
                                <p>View individual accounts for details.</p>
                                <button class="ga-view-btn">View</button>
                            </div>
                        </div>
                        <div class="ga-notification-item">
                            <div class="ga-notification-icon error">!</div>
                            <div class="ga-notification-content">
                                <h4>2 accounts could benefit from improved<br>security</h4>
                                <p>Check out suggestions to improve the security<br>of 2 accounts.</p>
                                <button class="ga-view-btn">View</button>
                            </div>
                        </div>
                        <div class="ga-notification-item">
                            <div class="ga-notification-icon warn">i</div>
                            <div class="ga-notification-content">
                                <h4>Thanks for verifying 1 account!</h4>
                                <p>Thanks for verifying! The verified advertiser<br>name and location for each of these
                                    accounts<br>will now appear in your ad disclosures. We'll let<br> you know if we
                                    need more information in<br>future.</p>
                                <button class="ga-text-btn">Learn more</button>
                            </div>
                        </div>
                    </div>
                </transition>
                <div class="ga-profile">
                    <span>{{ account.phone }} {{ account.id }}</span>
                    <small>{{ account.name }}</small>
                </div>
                <div class="ga-avatar">伟全</div>
            </div>
        </header>

        <div class="ga-shell">
            <aside class="ga-rail" aria-label="Main navigation">
                <div class="ga-create-block">
                    <button class="ga-create-button" type="button" aria-label="Create">
                        <span class="ga-create-tooltip">Create</span>
                    </button>
                    <span class="ga-create-text">Create</span>
                </div>
                <!-- <a class="ga-rail-item" href="/aw/campaigns">
                    <span class="material-symbols-outlined">overview</span>
                    <span>Overview</span>
                </a> -->
                <a class="ga-rail-item" href="/aw/campaigns">
                    <i class="material-symbols-outlined-extended">team_drive_outline</i>
                    <span>Accounts</span>
                </a>
                <a class="ga-rail-item active" href="/aw/campaigns">
                    <span class="material-symbols-outlined">campaign</span>
                    <span>Campaigns</span>
                </a>
                <a class="ga-rail-item" href="#">
                    <span class="material-symbols-outlined">rewarded_ads</span>
                    <span>Goals</span>
                </a>
                <a class="ga-rail-item" href="#">
                    <span class="material-symbols-outlined">construction</span>
                    <span>Tools</span>
                </a>
                <a class="ga-rail-item" href="#">
                    <span class="material-symbols-outlined">payment</span>
                    <span>Billing</span>
                </a>
                <a class="ga-rail-item" href="#">
                    <span class="material-symbols-outlined">settings</span>
                    <span>Admin</span>
                </a>
            </aside>

            <nav class="ga-sidebar" aria-label="Campaign navigation" @mouseover="handleTooltipMouseOver"
                @mouseleave="hideTooltip" @mousemove="handleMouseMove">
                <div class="ga-sidebar-group" href="#">
                    <button class="ga-sidebar-group-title" type="button">
                        <span data-tooltip="Overview">Overview</span>
                    </button>
                </div>
                <div class="ga-sidebar-group" href="#">
                    <button class="ga-sidebar-group-title" type="button">
                        <span data-tooltip="Recommendations">Recommendations</span>
                    </button>
                </div>
                <div class="ga-sidebar-group" :class="{ open: ads_isInsightsReportsOpen }">
                    <button class="ga-sidebar-group-title" type="button"
                        @click="ads_isInsightsReportsOpen = !ads_isInsightsReportsOpen">
                        <span data-tooltip="Insights and reports">Insights and reports</span>
                        <span class="material-symbols-outlined">{{ ads_isInsightsReportsOpen ? 'expand_less' :
                            'expand_more' }}</span>
                    </button>
                    <div class="ga-sidebar-submenu">
                        <a class="ga-sidebar-link" 
   :class="{ active: pageMode === 'reporteditor' }" 
   href="#" 
   @click="switchPage('reporteditor')" 
   data-tooltip="Report editor">
    Report editor
</a>
                        <a class="ga-sidebar-link" href="#" data-tooltip="Dashboards"
                            data-tooltip="Dashboards">Dashboards</a>
                    </div>
                </div>
                <div class="ga-sidebar-group" :class="{ open: ads_isCampaignOpen }">
                    <button class="ga-sidebar-group-title" type="button"
                        @click="ads_isCampaignOpen = !ads_isCampaignOpen" data-tooltip="Campaigns">
                        <span>Campaigns</span>
                        <span class="material-symbols-outlined">{{ ads_isCampaignOpen ? 'expand_less' : 'expand_more'
                            }}</span>
                    </button>
                    <div class="ga-sidebar-submenu">
                        <a class="ga-sidebar-link" :class="{ active: pageMode === 'campaigns' }" href="/aw/campaigns"
                            data-tooltip="Campaigns">Campaigns</a>
                        <a class="ga-sidebar-link" :class="{ active: pageMode === 'adgroups' }" :href="adGroupsHref"
                            data-tooltip="Ad groups">Ad groups</a>
                        <a class="ga-sidebar-link" :class="{ active: pageMode === 'adassets' }" :href="adAssetsHref"
                            data-tooltip="Ad assets">Ad assets</a>
                        <a class="ga-sidebar-link" href="#" data-tooltip="Experiments">Experiments</a>
                    </div>
                </div>
                <div class="ga-sidebar-group" :class="{ open: ads_isAssetsOpen }">
                    <button class="ga-sidebar-group-title" type="button" @click="ads_isAssetsOpen = !ads_isAssetsOpen"
                        data-tooltip="Assets">
                        <span>Assets</span>
                        <span class="material-symbols-outlined">{{ ads_isAssetsOpen ? 'expand_less' : 'expand_more'
                            }}</span>
                    </button>
                    <div class="ga-sidebar-submenu">
                        <a class="ga-sidebar-link" :class="{ active: pageMode === 'adassets' }" :href="adAssetsHref"
                            data-tooltip="Assets">Assets</a>
                    </div>
                </div>
                <div class="ga-sidebar-group" href="#">
                    <button class="ga-sidebar-group-title" type="button">
                        <span data-tooltip="Audiences, keywords, and content">Audiences, keywords, and
                            <br>content</span>
                        <span class="material-symbols-outlined">expand_more</span>
                    </button>
                </div>
                <div class="ga-sidebar-group" href="#">
                    <button class="ga-sidebar-group-title" type="button">
                        <span data-tooltip="Change history">Change history</span>
                    </button>
                </div>
            </nav>

            <main class="ga-main" :class="{ 'is-refreshing': isRefreshing }">
                <section v-if="pageMode !== 'reporteditor'" class="ga-context-bar" :class="{ hidden: isContextBarHidden }">
                    <div class="ga-selectors">
                        <div class="ga-selector active" v-if="!isContextBarHidden" @click.stop="toggleDropdown('view')">
                            <small>View (2 filters)</small>
                            <a><span class="material-symbols-outlined">home</span> All campaigns</a>
                            <span class="material-symbols-outlined">arrow_drop_down</span>
                            <div v-if="dropdown === 'view'" class="ga-dropdown">
                                <a href="/aw/campaigns">All campaigns</a>
                            </div>
                        </div>
                        <div class="ga-selector" :class="{ active: selectedCampaign }"
                            @click.stop="toggleDropdown('campaign')">
                            <small>{{ campaignSelectorLabel }}</small>
                            <a>{{ selectedCampaign ? selectedCampaign.campaign : 'Select a campaign' }}</a>
                            <span class="material-symbols-outlined">arrow_drop_down</span>
                            <div v-if="dropdown === 'campaign'" class="ga-dropdown wide">
                                <a v-for="campaign in campaignRows" :key="campaign.id"
                                    :href="campaignHref(campaign.campaign)">
                                    {{ campaign.campaign }}
                                </a>
                            </div>
                        </div>
                        <div v-if="pageMode !== 'campaigns'" class="ga-selector"
                            :class="{ active: pageMode === 'adassets' }" @click.stop="toggleDropdown('adgroup')">
                            <small>Ad groups</small>
                            <a>{{ pageMode === 'adassets' ? adGroup.adGroup : 'Select an ad group' }}</a>
                            <span class="material-symbols-outlined">arrow_drop_down</span>
                            <div v-if="dropdown === 'adgroup'" class="ga-dropdown">
                                <a :href="adAssetsHref">{{ adGroup.adGroup }}</a>
                            </div>
                        </div>
                    </div>
                    <div v-if="pageMode !== 'campaigns'" class="ga-state-line">
                        <span :class="['ga-dot', selectedCampaignStatusClass]"></span>
                        <span>{{ selectedCampaignStateLabel }}</span>
                        <span>Status: <a href="#" :class="{ danger: isSelectedCampaignProblem }">{{
                                selectedCampaignStatusText }}</a></span>
                        <span>Account: {{ selectedCampaign ? (selectedCampaign.Account || selectedCampaign.account) : '' }}</span>
                        <span>Type: {{ selectedCampaign ? (selectedCampaign.CampaignType || selectedCampaign.campaignType || 'App') : 'App' }}</span>
                        <span v-if="pageMode === 'adgroups'">Budget: <a href="#">{{ selectedCampaign ?
                                selectedCampaign.budget : '' }}</a></span>
                        <span v-if="pageMode === 'adassets'">Target CPA: <a href="#">{{ adGroup.targetCpa }}</a></span>
                        <a class="ga-settings-link" href="#">
                            <span class="material-symbols-outlined">settings</span>
                            {{ pageMode === 'adassets' ? 'Ad group settings' : 'Campaign settings' }}
                        </a>
                    </div>
                    <section v-if="pageMode === 'campaigns'" class="ga-page-filter-row">
                        <span>Filters</span>
                        <button class="ga-filter-badge" type="button">Campaign status: All</button>
                        <button class="ga-filter-badge" type="button">Ad group status: Enabled, Paused</button>
                        <button class="ga-filter-add" type="button">Add filter</button>
                    </section>
                </section>

                <section class="ga-page-head" :class="{ 'ga-page-head--adassets': pageMode === 'adassets' }" v-if="pageMode !== 'reporteditor'">
                    <div class="ga-page-head-heading">
                        <h1>{{ pageTitle }}</h1>
                        <div v-if="isContextBarHidden && (pageMode === 'campaigns' || pageMode === 'adassets')" class="ga-page-head-selector-wrapper">
                            <div class="ga-ContextBarHidden">
                                <small>Ad groups</small>
                                <a>{{ pageMode === 'adassets' ? adGroup.adGroup : 'Ad group 1' }}</a>
                            </div>
                        </div>
                    </div>
                    <div v-if="pageMode === 'campaigns' || pageMode === 'adassets'" class="ga-date-row">
                        <span>{{ getDateOptionLabel(appliedDateOption) }}</span>
                        <button ref="dateSelectRef" class="ga-date-button" type="button" @click.stop="toggleDatePicker">
                            {{ dateRangeLabel }}
                            <span class="material-symbols-outlined">arrow_drop_down</span>
                        </button>
                        <button class="ga-date-nav" type="button" @click="shiftDateRange(-1)"
                            aria-label="Previous date range">
                            <span class="material-symbols-outlined">chevron_left</span>
                        </button>
                        <button class="ga-date-nav" type="button" @click="shiftDateRange(1)"
                            aria-label="Next date range">
                            <span class="material-symbols-outlined">chevron_right</span>
                        </button>
                        <a href="#" @click.prevent="applyQuickDateOption('last30Days')">Show last 30 days</a>
                    </div>
                    <transition name="date-picker">
                        <div v-if="showDatePicker" class="date-picker-dropdown" @click.stop :style="dropdownStyle">
                            <div class="date-picker-container">
                                <div class="date-picker-content">
                                    <div class="date-left-options">
                                        <div class="date-custom" :class="{ active: selectedDateOption === 'custom' }"
                                            @click="selectDateOption('custom')">
                                            Custom
                                        </div>

                                        <div class="date-options">
                                            <div class="date-option" :class="{ active: selectedDateOption === 'today' }"
                                                @click="selectDateOption('today')">
                                                Today
                                            </div>
                                            <div class="date-option"
                                                :class="{ active: selectedDateOption === 'yesterday' }"
                                                @click="selectDateOption('yesterday')">
                                                Yesterday
                                            </div>
                                            <div class="date-option"
                                                :class="{ active: selectedDateOption === 'thisWeekSunSat' }"
                                                @click="selectDateOption('thisWeekSunSat')">
                                                This week (Sun - Today)
                                            </div>
                                            <div class="date-option"
                                                :class="{ active: selectedDateOption === 'thisWeekMonSun' }"
                                                @click="selectDateOption('thisWeekMonSun')">
                                                This week (Mon - Today)
                                            </div>
                                            <div class="date-option"
                                                :class="{ active: selectedDateOption === 'last7Days' }"
                                                @click="selectDateOption('last7Days')">
                                                Last 7 days (up to yesterday)
                                            </div>
                                            <div class="date-option"
                                                :class="{ active: selectedDateOption === 'lastWeekSunSat' }"
                                                @click="selectDateOption('lastWeekSunSat')">
                                                Last week (Sun - Sat)
                                            </div>
                                            <div class="date-option"
                                                :class="{ active: selectedDateOption === 'lastWeekMonSun' }"
                                                @click="selectDateOption('lastWeekMonSun')">
                                                Last week (Mon - Sun)
                                            </div>
                                            <div class="date-option"
                                                :class="{ active: selectedDateOption === 'lastBusinessWeek' }"
                                                @click="selectDateOption('lastBusinessWeek')">
                                                Last business week (Mon - Fri)
                                            </div>
                                            <div class="date-option"
                                                :class="{ active: selectedDateOption === 'last14Days' }"
                                                @click="selectDateOption('last14Days')">
                                                Last 14 days (up to yesterday)
                                            </div>
                                            <div class="date-option"
                                                :class="{ active: selectedDateOption === 'thisMonth' }"
                                                @click="selectDateOption('thisMonth')">
                                                This month
                                            </div>
                                            <div class="date-option"
                                                :class="{ active: selectedDateOption === 'last30Days' }"
                                                @click="selectDateOption('last30Days')">
                                                Last 30 days
                                            </div>
                                            <div class="date-option"
                                                :class="{ active: selectedDateOption === 'lastMonth' }"
                                                @click="selectDateOption('lastMonth')">
                                                Last month
                                            </div>
                                            <div class="date-option"
                                                :class="{ active: selectedDateOption === 'allTime' }"
                                                @click="selectDateOption('allTime')">
                                                All time
                                            </div>
                                        </div>

                                        <div class="compare-option">
                                            <span class="compare-label">Compare</span>
                                            <div :class="{ toggled: compareEnabled }"
                                                @click="compareEnabled = !compareEnabled">
                                                <div class="toggle-circle"></div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="calendar-section">
                                        <div class="date-inputs">
                                            <div class="date-input-wrapper" :class="{ active: selectingStartDate }"
                                                @click="selectStartDate">
                                                <div class="date-input-label">Start date*</div>
                                                <div class="date-input-value">{{ formattedDraftStartDate }}</div>
                                            </div>
                                            <div style="line-height: 49px;">—</div>
                                            <div class="date-input-wrapper" :class="{ active: !selectingStartDate }"
                                                @click="selectEndDate">
                                                <div class="date-input-label">End date*</div>
                                                <div class="date-input-value">{{ formattedDraftEndDate }}</div>
                                            </div>
                                        </div>

                                        <div class="calendar-nav-bar">
                                            <div class="calendar-nav-month">{{ calendarMonthYear }}</div>
                                            <div class="calendar-nav-buttons">
                                                <span class="material-symbols-outlined"
                                                    @click="navigateMonth(-1)">chevron_left</span>
                                                <span class="material-symbols-outlined"
                                                    @click="navigateMonth(1)">chevron_right</span>
                                            </div>
                                        </div>

                                        <div class="calendar-scroll-container">
                                            <div class="calendar-weekdays-fixed">
                                                <div class="weekday">S</div>
                                                <div class="weekday">M</div>
                                                <div class="weekday">T</div>
                                                <div class="weekday">W</div>
                                                <div class="weekday">T</div>
                                                <div class="weekday">F</div>
                                                <div class="weekday">S</div>
                                            </div>

                                            <div class="calendar-months-scroll">
                                                <div v-for="monthData in calendarMonths" :key="monthData.date"
                                                    class="calendar-month">
                                                    <div v-if="!monthData.showTitleInline" class="calendar-month-title">
                                                        {{
                                                        monthData.monthYear }}</div>
                                                    <div class="calendar-days">
                                                        <div v-for="(week, weekIndex) in monthData.weeks" :key="week"
                                                            class="calendar-week">
                                                            <div v-if="monthData.showTitleInline && weekIndex === 0"
                                                                class="calendar-month-title-inline">{{
                                                                monthData.monthYear }}
                                                            </div>
                                                            <div v-for="day in week" :key="day.date"
                                                                class="calendar-day" :class="{
                                                                    'other-month': !day.isCurrentMonth,
                                                                    'selected': isSameDay(day.date, draftStartDate),
                                                                    'in-range': isInRange(day.date),
                                                                    'start-date': isSameDay(day.date, draftStartDate) && !isSameDay(draftStartDate, draftEndDate),
                                                                    'end-date': isSameDay(day.date, draftEndDate) && !isSameDay(draftStartDate, draftEndDate),
                                                                    'single-date': isSameDay(day.date, draftStartDate) && isSameDay(draftStartDate, draftEndDate)
                                                                }" @click="selectCalendarDate(day.date)">
                                                                <span class="day-number">{{ day.date.getDate() }}</span>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="date-picker-actions" v-if="draftStartDate && draftEndDate">
